# Required for hosted or database-backed deployments.
# Generate a long random value and configure the same value in Netlify.
JWT_SECRET=

# Required for persistent production data.
# Example: mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL=

# Optional AI and storage proxy configuration.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Keep both false in production unless you intentionally want demo login tiles/accounts.
IDP_ENABLE_SAMPLE_ACCOUNTS=false
VITE_SHOW_SAMPLE_ACCOUNTS=false

# Optional SSO/OAuth settings.
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
