# Netlify staging/demo environment variables
# Add these in Netlify: Site configuration -> Environment variables.
# Redeploy after changing VITE_* variables because they are baked into the frontend build.

# Required for login/session security on Netlify.
# Replace this with a long random value and keep it private.
JWT_SECRET=replace-with-a-long-random-secret

# Required for real persistent admin/user/organisation/document data.
# Example:
# DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL=

# Shows the Admin/User quick-login buttons on the hosted Netlify page.
# Use true only for staging/demo. For production, set this to false.
VITE_SHOW_SAMPLE_ACCOUNTS=true

# Allows the sample Admin/User credentials to work on the server.
# Use true only for staging/demo. For production, set this to false.
IDP_ENABLE_SAMPLE_ACCOUNTS=true

# Optional AI integration.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional SSO/OAuth settings.
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
